{
  "product": {
    "name": "product",
    "fields": [
      {
        "name": "name",
        "kind": "string",
        "comment": "产品名称"
      },
      {
        "name": "description",
        "kind": "string",
        "comment": "",
        "default": "'' COMMENT '产品介绍'"
      },
      {
        "name": "main_image_url",
        "kind": "string",
        "comment": "",
        "default": "'' COMMENT '主图'"
      },
      {
        "name": "detail_image_urls",
        "kind": "array<string>",
        "comment": "",
        "default": "[] COMMENT '详情图'"
      },
      {
        "name": "category",
        "kind": "record<product_category>",
        "comment": "",
        "default": "NONE COMMENT '类目'"
      },
      {
        "name": "base_price",
        "kind": "float",
        "comment": "",
        "default": "0 COMMENT '如法造基准价'"
      },
      {
        "name": "sync_source_id",
        "kind": "string",
        "comment": "如法造产品ID"
      },
      {
        "name": "synced_at",
        "kind": "datetime",
        "comment": "",
        "default": "time::now() COMMENT '同步时间'"
      },
      {
        "name": "created_at",
        "kind": "datetime",
        "comment": ""
      },
      {
        "name": "updated_at",
        "kind": "datetime",
        "comment": ""
      }
    ]
  },
  "product_category": {
    "name": "product_category",
    "fields": [
      {
        "name": "name",
        "kind": "string",
        "comment": "类目名称"
      },
      {
        "name": "sort_order",
        "kind": "int",
        "comment": "",
        "default": "0 COMMENT '排序'"
      },
      {
        "name": "created_at",
        "kind": "datetime",
        "comment": ""
      }
    ]
  },
  "product_variant": {
    "name": "product_variant",
    "fields": [
      {
        "name": "sku",
        "kind": "string",
        "comment": "SKU编码"
      },
      {
        "name": "name",
        "kind": "string",
        "comment": "规格名称"
      },
      {
        "name": "spu",
        "kind": "record<product>",
        "comment": "所属SPU"
      },
      {
        "name": "base_price",
        "kind": "float",
        "comment": "",
        "default": "0 COMMENT '如法造基准价'"
      },
      {
        "name": "sync_source_id",
        "kind": "string",
        "comment": "如法造SKU ID"
      },
      {
        "name": "created_at",
        "kind": "datetime",
        "comment": ""
      }
    ]
  },
  "customer": {
    "name": "customer",
    "fields": [
      {
        "name": "name",
        "kind": "string",
        "comment": "姓名"
      },
      {
        "name": "phone",
        "kind": "string",
        "comment": "",
        "default": "'' COMMENT '电话'"
      },
      {
        "name": "wechat",
        "kind": "string",
        "comment": "",
        "default": "'' COMMENT '微信'"
      },
      {
        "name": "address",
        "kind": "string",
        "comment": "",
        "default": "'' COMMENT '地址'"
      },
      {
        "name": "notes",
        "kind": "string",
        "comment": "",
        "default": "'' COMMENT '备注'"
      },
      {
        "name": "created_at",
        "kind": "datetime",
        "comment": ""
      },
      {
        "name": "updated_at",
        "kind": "datetime",
        "comment": ""
      }
    ]
  },
  "pricing": {
    "name": "pricing",
    "fields": [
      {
        "name": "variant",
        "kind": "record<product_variant>",
        "comment": "SKU"
      },
      {
        "name": "price",
        "kind": "float",
        "comment": "售价"
      },
      {
        "name": "is_active",
        "kind": "bool",
        "comment": "",
        "default": "true COMMENT '启用'"
      },
      {
        "name": "created_at",
        "kind": "datetime",
        "comment": ""
      },
      {
        "name": "updated_at",
        "kind": "datetime",
        "comment": ""
      }
    ]
  },
  "store_inventory": {
    "name": "store_inventory",
    "fields": [
      {
        "name": "variant",
        "kind": "record<product_variant>",
        "comment": "SKU"
      },
      {
        "name": "quantity",
        "kind": "int",
        "comment": "",
        "default": "0 COMMENT '数量'"
      },
      {
        "name": "updated_at",
        "kind": "datetime",
        "comment": ""
      }
    ]
  },
  "inventory_count": {
    "name": "inventory_count",
    "fields": [
      {
        "name": "variant",
        "kind": "record<product_variant>",
        "comment": "SKU"
      },
      {
        "name": "prev_stock",
        "kind": "int",
        "comment": "",
        "default": "0 COMMENT '盘点前库存'"
      },
      {
        "name": "actual_stock",
        "kind": "int",
        "comment": "",
        "default": "0 COMMENT '实盘库存'"
      },
      {
        "name": "diff",
        "kind": "int",
        "comment": "",
        "default": "0 COMMENT '差异'"
      },
      {
        "name": "reason",
        "kind": "string",
        "comment": "",
        "default": "'' COMMENT '原因'"
      },
      {
        "name": "counted_by",
        "kind": "record<user>",
        "comment": "盘点人"
      },
      {
        "name": "created_at",
        "kind": "datetime",
        "comment": ""
      }
    ]
  },
  "sales_order": {
    "name": "sales_order",
    "fields": [
      {
        "name": "order_no",
        "kind": "string",
        "comment": "订单号"
      },
      {
        "name": "customer",
        "kind": "record<customer>",
        "comment": "",
        "default": "NONE COMMENT '客户'"
      },
      {
        "name": "total_amount",
        "kind": "float",
        "comment": "",
        "default": "0 COMMENT '总金额'"
      },
      {
        "name": "status",
        "kind": "string",
        "comment": "",
        "assert": "$value IN ['待付款', '已付款', '已发货', '已完成', '已取消']",
        "default": "'待付款' COMMENT '状态'"
      },
      {
        "name": "notes",
        "kind": "string",
        "comment": "",
        "default": "'' COMMENT '备注'"
      },
      {
        "name": "sync_status",
        "kind": "string",
        "comment": "",
        "assert": "$value IN ['pending', 'synced', 'failed']",
        "default": "'pending' COMMENT '同步状态'"
      },
      {
        "name": "synced_at",
        "kind": "datetime",
        "comment": "",
        "default": "NONE COMMENT '同步时间'"
      },
      {
        "name": "created_by",
        "kind": "record<user>",
        "comment": "操作人"
      },
      {
        "name": "created_at",
        "kind": "datetime",
        "comment": ""
      }
    ]
  },
  "order_item": {
    "name": "order_item",
    "fields": [
      {
        "name": "order",
        "kind": "record<sales_order>",
        "comment": "订单"
      },
      {
        "name": "variant",
        "kind": "record<product_variant>",
        "comment": "SKU"
      },
      {
        "name": "quantity",
        "kind": "int",
        "comment": "",
        "default": "1 COMMENT '数量'"
      },
      {
        "name": "unit_price",
        "kind": "float",
        "comment": "",
        "default": "0 COMMENT '单价'"
      },
      {
        "name": "amount",
        "kind": "float",
        "comment": "",
        "default": "0 COMMENT '小计'"
      }
    ]
  },
  "restock_request": {
    "name": "restock_request",
    "fields": [
      {
        "name": "variant",
        "kind": "record<product_variant>",
        "comment": "SKU"
      },
      {
        "name": "quantity",
        "kind": "int",
        "comment": "",
        "default": "0 COMMENT '数量'"
      },
      {
        "name": "reason",
        "kind": "string",
        "comment": "",
        "default": "'' COMMENT '原因'"
      },
      {
        "name": "status",
        "kind": "string",
        "comment": "",
        "assert": "$value IN ['待处理', '已处理', '已拒绝']",
        "default": "'待处理' COMMENT '状态'"
      },
      {
        "name": "created_by",
        "kind": "record<user>",
        "comment": "操作人"
      },
      {
        "name": "created_at",
        "kind": "datetime",
        "comment": ""
      }
    ]
  },
  "user": {
    "name": "user",
    "fields": [
      {
        "name": "name",
        "kind": "string",
        "comment": "用户名"
      },
      {
        "name": "display_name",
        "kind": "string",
        "comment": "",
        "default": "'' COMMENT '显示名称'"
      },
      {
        "name": "password_hash",
        "kind": "string",
        "comment": "密码哈希"
      },
      {
        "name": "role",
        "kind": "string",
        "comment": "",
        "assert": "$value IN ['管理员', '店员']",
        "default": "'店员' COMMENT '角色'"
      },
      {
        "name": "created_at",
        "kind": "datetime",
        "comment": ""
      }
    ]
  },
  "agent_message": {
    "name": "agent_message",
    "fields": [
      {
        "name": "user_input",
        "kind": "string",
        "comment": "用户输入"
      },
      {
        "name": "response",
        "kind": "string",
        "comment": "",
        "default": "'' COMMENT 'Agent 回复'"
      },
      {
        "name": "attachments",
        "kind": "array",
        "comment": "",
        "default": "[] COMMENT '附件'"
      },
      {
        "name": "actions",
        "kind": "array",
        "comment": "",
        "default": "[] COMMENT 'Actions'"
      },
      {
        "name": "status",
        "kind": "string",
        "comment": "",
        "assert": "$value IN ['pending', 'processing', 'done', 'error']",
        "default": "'pending' COMMENT '状态'"
      },
      {
        "name": "session_id",
        "kind": "string",
        "comment": "会话ID"
      },
      {
        "name": "created_by",
        "kind": "record<user>",
        "comment": "创建人"
      },
      {
        "name": "created_at",
        "kind": "datetime",
        "comment": ""
      },
      {
        "name": "processed_at",
        "kind": "datetime",
        "comment": "",
        "default": "NONE COMMENT '处理时间'"
      }
    ]
  }
}